generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AchievementCategory {
  PROGRESS
  COMPLETION
  STREAK
  COMMUNITY
  SPECIAL
}

model User {
  /// Clerk user ID.
  id                String             @id @db.Text
  email             String?            @unique @db.Text
  name              String?            @db.Text
  imageUrl          String?            @db.Text
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  courseProgresses  CourseProgress[]
  lessonCompletions LessonCompletion[]
  achievements      UserAchievement[]
  pointsLedger      UserPoints[]

  @@index([createdAt])
}

model CourseProgress {
  id                    String    @id @default(cuid())
  userId                String    @db.Text
  courseId              String    @db.Text
  courseSlug            String?   @db.Text
  completedLessons      Int       @default(0)
  totalLessons          Int       @default(0)
  progressPercentage    Decimal   @default(0) @db.Decimal(5, 2)
  pointsEarned          Int       @default(0)
  startedAt             DateTime  @default(now())
  lastLessonCompletedAt DateTime?
  completedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([userId, updatedAt])
  @@index([userId, progressPercentage])
}

model LessonCompletion {
  id                 String    @id @default(cuid())
  userId             String    @db.Text
  courseId           String    @db.Text
  lessonId           String    @db.Text
  lessonSlug         String?   @db.Text
  moduleId           String?   @db.Text
  completed          Boolean   @default(true)
  progressPercentage Decimal   @default(100) @db.Decimal(5, 2)
  pointsAwarded      Int       @default(0)
  completedAt        DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
  @@index([courseId, completedAt])
}

model Achievement {
  id               String              @id @default(cuid())
  key              String              @unique @db.Text
  title            String              @db.Text
  description      String?             @db.Text
  category         AchievementCategory @default(PROGRESS)
  icon             String?             @db.Text
  pointsReward     Int                 @default(0)
  threshold        Int?
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  userAchievements UserAchievement[]

  @@index([category, isActive])
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String      @db.Text
  achievementId String
  awardedAt     DateTime    @default(now())
  progressValue Int?
  pointsAwarded Int         @default(0)
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([achievementId, awardedAt])
  @@index([userId, awardedAt])
}

model UserPoints {
  id           String    @id @default(cuid())
  userId       String    @db.Text
  source       String    @db.Text
  sourceId     String?   @db.Text
  points       Int
  balanceAfter Int?
  awardedAt    DateTime  @default(now())
  expiresAt    DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, awardedAt])
  @@index([userId, points])
  @@index([source, sourceId])
}
